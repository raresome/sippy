<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <application
        android:allowBackup="true"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:isGame="true"
        android:theme="@style/AppTheme">

        <!-- AdMob. Must match ADMOB_APP_ID in www/js/gameids.js — the Mobile Ads SDK
             throws at init if this is absent or mismatched. -->
        <meta-data
            android:name="com.google.android.gms.ads.APPLICATION_ID"
            android:value="ca-app-pub-6764599135936645~5598324496" />

        <!-- Defer ad SDK startup off the launch path so the title screen paints first. -->
        <meta-data
            android:name="com.google.android.gms.ads.flag.OPTIMIZE_INITIALIZATION"
            android:value="true" />
        <meta-data
            android:name="com.google.android.gms.ads.flag.OPTIMIZE_AD_LOADING"
            android:value="true" />

        <!-- Play Games Services v2 — DISABLED until a real APP_ID exists.
             Google Play Services reads this meta-data itself and kicks off a sign-in without
             going through our plugin, so a placeholder here makes GMS log:
               "Game (com.genartstudios.sippy) failed to include a non-numeric
                Play Games Services application id in their AndroidManifest"
             on every launch. Our own guard in PlayGamesPlugin.kt cannot prevent that.

             TO ENABLE: put the numeric id from Play Console → Grow → Play Games Services into
             game_app_id in strings.xml, then uncomment the meta-data below. Also fill in
             LEADERBOARDS / ACHIEVEMENTS in www/js/gameids.js.
        <meta-data
            android:name="com.google.android.gms.games.APP_ID"
            android:value="@string/game_app_id" />
        -->

        <meta-data
            android:name="com.google.android.gms.version"
            android:value="@integer/google_play_services_version" />

        <activity
            android:configChanges="orientation|keyboardHidden|keyboard|screenSize|locale|smallestScreenSize|screenLayout|uiMode|navigation"
            android:name=".MainActivity"
            android:label="@string/title_activity_main"
            android:theme="@style/AppTheme.NoActionBarLaunch"
            android:launchMode="singleTask"
            android:screenOrientation="portrait"
            android:exported="true">

            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>

        </activity>

        <provider
            android:name="androidx.core.content.FileProvider"
            android:authorities="${applicationId}.fileprovider"
            android:exported="false"
            android:grantUriPermissions="true">
            <meta-data
                android:name="android.support.FILE_PROVIDER_PATHS"
                android:resource="@xml/file_paths"></meta-data>
        </provider>
    </application>

    <!-- Permissions -->

    <uses-permission android:name="android.permission.INTERNET" />

    <!-- Required for the Mobile Ads SDK on targetSdk 33+. Declared honestly in the Play
         Data Safety form as "Device or other IDs → Advertising ID" (spec §9). -->
    <uses-permission android:name="com.google.android.gms.permission.AD_ID" />
</manifest>
