{
  "name": "sippy",
  "version": "1.0.0",
  "private": true,
  "description": "SIPPY — one more sip. A push-your-luck HTML5 canvas game wrapped by Capacitor.",
  "scripts": {
    "dev": "serve www",
    "sync": "cap sync android",
