    "android:release": "cd android && gradlew.bat bundleRelease"
  },
  "dependencies": {
    "@capacitor-community/admob": "^7.2.0",
    "@capacitor-firebase/analytics": "^7.5.0",
    "@capacitor/android": "^7.0.0",
    "@capacitor/core": "^7.0.0",
    "@capacitor/haptics": "^7.0.0",
    "@capacitor/preferences": "^7.0.0",
    "sippy-playgames": "file:plugins/playgames"
  },
  "devDependencies": {
    "@capacitor/cli": "^7.0.0",
    "serve": "^14.2.4"
  }
}
